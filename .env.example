# Reference de variables d'environnement pour le deploiement.
# Ce fichier n'est pas charge automatiquement par Django : configure ces valeurs
# dans ton hebergeur, ton service systemd, Docker, Render, Railway, Heroku, etc.

DJANGO_ENV=production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=generate-a-unique-secret-key-with-at-least-50-random-characters-for-production
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Base de donnees recommandee en production.
DATABASE_URL=postgresql://user:password@host:5432/gesgym?sslmode=require
DB_CONN_MAX_AGE=60

# HTTPS et cookies.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_AGE=28800
DJANGO_USE_X_FORWARDED_HOST=False

# HSTS.
# Laisse ces valeurs a True si tous tes sous-domaines web doivent forcer le HTTPS.
# Si tu gardes volontairement un sous-domaine HTTP, repasse-les a False.
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# Fichiers medias.
# Laisse False si les medias sont servis par Nginx, un bucket S3, Cloudinary, etc.
# Passe a True uniquement pour une premiere version mono-serveur.
DJANGO_SERVE_MEDIA=False

# Email d'erreurs serveur.
DJANGO_ADMINS=Admin:admin@example.com
DJANGO_EMAIL_HOST=smtp.example.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=apikey-or-username
DJANGO_EMAIL_HOST_PASSWORD=secret
DJANGO_EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com
DJANGO_SERVER_EMAIL=server@example.com

# Bootstrap admin.
# Utilise ces variables uniquement pour un premier deploiement ou un bootstrap
# volontaire. Elles ne reinitialisent plus le mot de passe d'un compte existant.
DJANGO_BOOTSTRAP_SUPERUSER_USERNAME=admin-bootstrap
DJANGO_BOOTSTRAP_SUPERUSER_PASSWORD=change-me-before-first-production-migrate
DJANGO_BOOTSTRAP_SUPERUSER_EMAIL=admin@example.com

# Liens sociaux optionnels affiches sur la page de connexion.
DJANGO_SOCIAL_FACEBOOK_URL=https://facebook.com/votre-page
DJANGO_SOCIAL_TWITTER_URL=https://x.com/votre-compte
DJANGO_SOCIAL_GITHUB_URL=https://github.com/votre-organisation

# Localisation.
DJANGO_LANGUAGE_CODE=fr-fr
DJANGO_TIME_ZONE=Africa/Kinshasa

# Observabilite.
DJANGO_LOG_LEVEL=INFO
