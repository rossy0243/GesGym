# Reference de variables d'environnement pour le deploiement.
# Ce fichier n'est pas charge automatiquement par Django : configure ces valeurs
# dans ton hebergeur, ton service systemd, Docker, Render, Railway, Heroku, etc.

DJANGO_ENV=production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Base de donnees recommandee en production.
DATABASE_URL=postgresql://user:password@host:5432/gesgym?sslmode=require
DB_CONN_MAX_AGE=60

# HTTPS et cookies.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_AGE=28800

# HSTS.
# Active INCLUDE_SUBDOMAINS et PRELOAD uniquement si tous les sous-domaines sont en HTTPS.
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Email d'erreurs serveur.
DJANGO_ADMINS=Admin:admin@example.com
DJANGO_EMAIL_HOST=smtp.example.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=apikey-or-username
DJANGO_EMAIL_HOST_PASSWORD=secret
DJANGO_EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com
DJANGO_SERVER_EMAIL=server@example.com

# Localisation.
DJANGO_LANGUAGE_CODE=fr-fr
DJANGO_TIME_ZONE=Africa/Kinshasa

# Observabilite.
DJANGO_LOG_LEVEL=INFO
